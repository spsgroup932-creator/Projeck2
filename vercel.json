{
    "version": 2,
    "framework": null,
    "outputDirectory": "public",
    "functions": {
        "api/main.php": { "runtime": "vercel-php@0.7.1" }
    },
    "routes": [
        { "src": "/build/(.*)", "dest": "/build/$1" },
        { "src": "/(favicon.ico|manifest.json|robots.txt|sw.js|debug.php|icons/.*)", "dest": "/$1" },
        { "src": "/(.*)", "dest": "/api/main.php" }
    ]
}
